-- ALL BLUE: 강사 신뢰검증 스키마 (instructors, policies, penalties_log)
-- 참고: 이 프로젝트에는 아직 실제 로그인/인증 시스템이 없으므로(마스터 테스트 툴바로 역할 전환),
-- 데모 목적상 RLS는 공개 조회(select) + permissive insert/update로 설정한다.
-- 향후 실 인증(Supabase Auth) 도입 시 반드시 정책을 강화해야 한다.

create table public.instructors (
  id text primary key,
  profile_id text,
  name text not null,
  avatar_url text,
  agency text,
  license_file_names text[] default '{}',
  signature_data_url text,
  verified_status boolean not null default false,
  total_logs integer not null default 0,
  experience_years integer not null default 0,
  completion_rate numeric not null default 0,
  rating numeric not null default 0,
  penalty_count integer not null default 0,
  bio text,
  created_at timestamptz not null default now()
);

alter table public.instructors enable row level security;

create policy "instructors_public_select" on public.instructors
  for select using (true);

create policy "instructors_public_insert" on public.instructors
  for insert with check (true);

create policy "instructors_public_update" on public.instructors
  for update using (true) with check (true);

create table public.policies (
  id uuid primary key default gen_random_uuid(),
  category text not null check (category in ('refund', 'violation', 'enforcement')),
  sort_order integer not null default 0,
  title text not null,
  description text,
  rate text,
  created_at timestamptz not null default now()
);

alter table public.policies enable row level security;

create policy "policies_public_select" on public.policies
  for select using (true);

create table public.penalties_log (
  id uuid primary key default gen_random_uuid(),
  instructor_id text not null references public.instructors(id) on delete cascade,
  violation_type text not null,
  description text,
  created_at timestamptz not null default now()
);

alter table public.penalties_log enable row level security;

create policy "penalties_log_public_select" on public.penalties_log
  for select using (true);

create policy "penalties_log_public_insert" on public.penalties_log
  for insert with check (true);

-- 트리거: penalties_log에 새 위반 기록이 insert되면 해당 강사의 penalty_count를 실시간으로 +1
create or replace function public.increment_instructor_penalty_count()
returns trigger
language plpgsql
security definer
set search_path = public
as $$
begin
  update public.instructors
  set penalty_count = penalty_count + 1
  where id = new.instructor_id;
  return new;
end;
$$;

create trigger trg_increment_instructor_penalty_count
  after insert on public.penalties_log
  for each row
  execute function public.increment_instructor_penalty_count();

