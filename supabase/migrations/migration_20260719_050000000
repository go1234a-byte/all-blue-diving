-- ALL BLUE: 최소 인원 자동 마감/취소 정책 컬럼 추가
-- 투어 출발일 30일 전 자동으로 모집을 마감하고, 그 시점에 확정 예약 수가
-- min_participants(최소 인원) 미만이면 강사가 설정한 under_min_policy에 따라
-- ("proceed" = 그대로 진행 / "cancel" = 투어 취소 + 전액환불) 처리한다.
-- auto_close_processed는 동일 투어에 대해 자동 마감 로직이 중복 실행되지 않도록 막는 플래그다.

alter table public.tours
  add column if not exists min_participants integer not null default 1,
  add column if not exists under_min_policy text not null default 'cancel'
    check (under_min_policy in ('proceed', 'cancel')),
  add column if not exists auto_close_processed boolean not null default false;

-- 강사가 투어 생성 시 매번 작성하는 전자 서약 기록 (신규 조항: 최소 인원 미달 시
-- 진행을 선택한 경우 발생하는 모든 책임은 현장 강사 본인에게 있음을 서약).
alter table public.tours
  add column if not exists pledge_signer_name text,
  add column if not exists pledge_agreed_at timestamptz,
  add column if not exists pledge_signature_data_url text;
