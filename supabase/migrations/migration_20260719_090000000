-- ALL BLUE: 쿠폰/프로모션 코드 기능 추가

create table if not exists public.coupons (
  id uuid primary key default gen_random_uuid(),
  code text not null unique,
  discount_type text not null check (discount_type in ('percent', 'fixed')),
  discount_value integer not null check (discount_value > 0),
  min_purchase integer not null default 0,
  max_discount integer,
  expires_at timestamptz,
  usage_limit integer,
  used_count integer not null default 0,
  active boolean not null default true,
  created_at timestamptz not null default now()
);

alter table public.coupons enable row level security;

-- 쿠폰 코드 조회/검증은 로그인 여부와 무관하게 결제 화면에서 필요하므로 select는 공개한다.
create policy "coupons_select_public" on public.coupons
  for select using (true);

-- 생성/수정/삭제는 관리자만 가능해야 하지만, 이 프로젝트는 관리자 화면을 서비스 role 키가 아닌
-- 클라이언트 anon 키로 운영하므로(MasterRoleToolbar 데모 전환 구조) 우선 전체 허용으로 두고,
-- 실제 운영 전환 시 관리자 역할 체크(auth.jwt() ->> 'role' 등)로 좁혀야 한다.
create policy "coupons_insert_all" on public.coupons for insert with check (true);
create policy "coupons_update_all" on public.coupons for update using (true);
create policy "coupons_delete_all" on public.coupons for delete using (true);

alter table public.bookings
  add column if not exists coupon_code text,
  add column if not exists discount_amount integer;
